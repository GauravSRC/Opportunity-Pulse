{
  "manifest_version": 3,
  "name": "OpportunityPulse",
  "version": "0.1.0",
  "description": "Shows your live match score on opportunity listing pages.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://remotive.com/*",
    "https://www.linkedin.com/jobs/*",
    "https://wellfound.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "OpportunityPulse"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://remotive.com/remote-jobs/*",
        "https://wellfound.com/jobs/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
