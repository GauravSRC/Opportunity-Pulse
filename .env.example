# ──────────────────────────────────────────────────────────────────────────
# OpportunityPulse environment template. Copy to .env and fill in.
# NEVER commit .env with real secrets (it is gitignored).
# ──────────────────────────────────────────────────────────────────────────

# --- Core services ---------------------------------------------------------
DATABASE_URL=postgresql+psycopg://opp:opp@localhost:5432/opportunitypulse
REDIS_URL=redis://localhost:6379/0
APP_ENV=development            # development | staging | production
APP_SECRET=change-me           # JWT signing / session secret
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- LLM provider (provider-agnostic layer: agents/llm.py) -----------------
# Default chat/reasoning provider used for drafting, query expansion, deadline LLM.
LLM_PROVIDER=anthropic         # anthropic | openai | ollama
LLM_MODEL=claude-opus-4-8      # see docs/ml-design.md / models/README.md
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434   # local fallback (zero cost)
OLLAMA_MODEL=llama3.1

# --- Embeddings ------------------------------------------------------------
EMBEDDING_PROVIDER=local       # local (sentence-transformers) | openai | hosted
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_ENABLED=true
RERANK_LATENCY_BUDGET_MS=300

# --- Web search / discovery (one interface, pick a provider) ---------------
SEARCH_PROVIDER=tavily         # tavily | serpapi
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- Source credentials ----------------------------------------------------
GITHUB_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# --- Crawler identity / politeness -----------------------------------------
CRAWLER_USER_AGENT=OpportunityPulseBot/0.1 (+https://example.com/bot-info)
HTTP_RATE_LIMIT_PER_HOST=1.0   # requests/sec default per host
HTTP_TIMEOUT_SECONDS=20

# --- Observability ---------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=opportunitypulse
PROMETHEUS_ENABLED=true

# --- Object storage for résumé blobs (encrypted at rest) -------------------
BLOB_STORE_PROVIDER=local      # local | s3
BLOB_STORE_PATH=./data/blobs
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Frontend / CORS -------------------------------------------------------
# Allowed browser origin for CORS. In production set this to your deployed
# frontend URL (e.g. https://opportunity-pulse.vercel.app).
WEB_ORIGIN=http://localhost:3000
# Base URL the Next.js app calls. In production set to your Render API URL
# (e.g. https://opportunity-pulse-api.onrender.com).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
